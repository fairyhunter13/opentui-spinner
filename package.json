{
  "name": "opentui-spinner",
  "version": "0.0.6",
  "description": "A small & opinionated spinner library",
  "license": "MIT",
  "type": "module",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./solid": {
      "import": {
        "types": "./dist/solid.d.mts",
        "default": "./dist/solid.mjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "biome check .",
    "lint:fix": "biome check . --write"
  },
  "keywords": [
    "opentui",
    "spinner",
    "cli",
    "terminal",
    "console",
    "tui"
  ],
  "dependencies": {
    "cli-spinners": "^3.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@fairyhunter13/opentui-core": "^0.1.113",
    "@fairyhunter13/opentui-solid": "^0.1.113",
    "@types/bun": "latest",
    "tsdown": "^0.16.0"
  },
  "peerDependencies": {
    "@fairyhunter13/opentui-core": "^0.1.113",
    "@fairyhunter13/opentui-solid": "^0.1.113",
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "@fairyhunter13/opentui-solid": {
      "optional": true
    }
  }
}
